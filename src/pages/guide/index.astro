---
import BaseLayout from "../../layouts/BaseLayout.astro";
import GuideCard from "../../components/GuideCard.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import { getGuideEntries } from "../../lib/content";

const guides = await getGuideEntries();
---

<BaseLayout title="Trip Options | Pullen's Way" description="Browse guided fishing trips, trail rides, boating outings, canoe trips, and seasonal adventures.">
  <section class="page-hero shell">
    <p class="eyebrow">Trip Options</p>
    <h1>Explore the experiences</h1>
    <p class="page-hero__intro">
      Each page is designed to explain the activity, the skill level, and the practical details guests need before they book.
    </p>
  </section>

  <section class="shell section">
    <SectionHeading
      eyebrow="Service Catalog"
      title="A repeatable format for fishing trips, trail rides, boating days, and seasonal outings."
      intro="These sample pages can be replaced with your dad's real trip descriptions, pricing notes, launch details, and photos."
    />

    <div class="guide-grid">
      {guides.map((entry) => <GuideCard entry={entry} />)}
    </div>
  </section>
</BaseLayout>
