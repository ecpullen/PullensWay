---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import FeatureCards from "../components/FeatureCards.astro";
import GuideCard from "../components/GuideCard.astro";
import site from "../data/site.json";
import { getGuideEntries } from "../lib/content";
import { withBase } from "../lib/paths";

const guides = (await getGuideEntries()).slice(0, 3);
---

<BaseLayout title={site.siteTitle} description={site.tagline}>
  <Hero eyebrow={site.heroEyebrow} title={site.heroTitle} intro={site.heroIntro} />

  <section class="shell section">
    <div class="announcement">{site.announcement}</div>
    <SectionHeading
      eyebrow="Built For Bookings"
      title="Position the business like a real outdoors service, not a hobby page."
      intro="The homepage now leads with trip categories, practical credibility, and a more rugged visual identity that fits lakes, trails, and outdoor equipment."
    />
    <FeatureCards />
  </section>

  <section class="shell section section--split">
    <div>
      <SectionHeading
        eyebrow="Trip Pages"
        title="Each outing can show the activity, the ideal guest, and what to expect."
        intro="These sample trip cards are structured for fishing days, boating outings, trail rides, canoe trips, and seasonal adventures."
      />
      <a class="button button--secondary" href={withBase("/guide")}>See all trip options</a>
    </div>

    <div class="stack">
      {guides.map((entry) => <GuideCard entry={entry} />)}
    </div>
  </section>

  <section class="shell section">
    <div class="callout">
      <div>
        <p class="eyebrow">Easy To Update</p>
        <h2>Change trip descriptions, photos, and trip details without rebuilding the design.</h2>
      </div>
      <p>
        Once your dad's real trip descriptions and photos are ready, the site can be updated by editing content files or the Git-backed CMS instead of touching the layout.
      </p>
    </div>
  </section>
</BaseLayout>
