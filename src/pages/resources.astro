---
import { render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import site from "../data/site.json";
import { getPageBySlug } from "../lib/content";

const page = await getPageBySlug("resources");
const hasWorkingMap =
  Boolean(site.mapEmbedUrl) &&
  !site.mapEmbedUrl.includes("1X0Jj2n0xgTgT9vP3b4l0vE9wJ7Q");

if (!page) {
  throw new Error("Resources page content is missing.");
}

const { Content } = await render(page);
---

<BaseLayout title={`${page.data.title} | Pullen's Way`} description={page.data.description}>
  <section class="page-hero shell">
    <p class="eyebrow">Trip Prep</p>
    <h1>{page.data.title}</h1>
    <p class="page-hero__intro">{page.data.intro}</p>
  </section>

  <section class="shell resource-grid">
    <article class="prose-card">
      <Content />
    </article>

    <aside class="map-card">
      <p class="eyebrow">Meeting Areas and Launches</p>
      <h2 class="map-card__title">Trailheads, launch points, and trip regions.</h2>
      <p class="map-card__intro">
        Add the real boating launches, fishing access points, and trail meeting areas here once your working map is ready.
      </p>

      {
        hasWorkingMap ? (
          <iframe
            title="Pullen's Way Map"
            src={site.mapEmbedUrl}
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"></iframe>
        ) : (
          <div class="map-placeholder">
            <div class="map-placeholder__badge">Map setup in progress</div>
            <h3>Use this area for your real trip map once launch points are finalized.</h3>
            <p>
              For now, this card avoids showing a broken embed. Replace the placeholder map URL in
              `src/data/site.json` with a real Google Maps or Google My Maps embed link when you have one.
            </p>
            <ul class="tag-list" aria-label="Map use cases">
              <li>Boat Launches</li>
              <li>Trailheads</li>
              <li>Fishing Access</li>
              <li>Meeting Spots</li>
            </ul>
            <a class="button button--secondary" href={`mailto:${site.contactEmail}`}>Ask for meeting details</a>
          </div>
        )
      }
    </aside>
  </section>

  <section class="shell section">
    <div class="feature-grid feature-grid--two">
      <article class="feature-card">
        <span class="feature-card__accent">Before A Fishing Trip</span>
        <h3>List meeting times, license reminders, what gear is included, and what guests should bring.</h3>
        <p>Coolers, weather layers, snacks, sunglasses, and any fish-cleaning expectations fit well here.</p>
      </article>
      <article class="feature-card">
        <span class="feature-card__accent">Before A Trail Ride</span>
        <h3>Cover trail conditions, clothing, eye protection, and how muddy or technical the ride may be.</h3>
        <p>This helps guests arrive prepared and keeps last-minute questions down.</p>
      </article>
    </div>
  </section>

  <section class="shell section">
    <div class="callout">
      <div>
        <p class="eyebrow">Trip Readiness</p>
        <h2>Use this page as the operational hub for launch points, waivers, weather notes, and checklists.</h2>
      </div>
      <p>Once the real business details are ready, this page can carry the practical information guests check right before they head out.</p>
    </div>
  </section>
</BaseLayout>
