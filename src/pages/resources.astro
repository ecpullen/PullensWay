---
import { render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import site from "../data/site.json";
import { getPageBySlug } from "../lib/content";

const page = await getPageBySlug("resources");

if (!page) {
  throw new Error("Resources page content is missing.");
}

const { Content } = await render(page);
---

<BaseLayout title={`${page.data.title} | Pullen's Way`} description={page.data.description}>
  <section class="page-hero shell">
    <p class="eyebrow">Trip Prep</p>
    <h1>{page.data.title}</h1>
    <p class="page-hero__intro">{page.data.intro}</p>
  </section>

  <section class="shell resource-grid">
    <article class="prose-card">
      <Content />
    </article>

    <aside class="map-card">
      <p class="eyebrow">Meeting Details</p>
      <h2 class="map-card__title">Everything guests need before they arrive.</h2>
      <p class="map-card__intro">
        Use this panel for the practical information guests care about most before a trip is confirmed.
      </p>

      <div class="map-placeholder">
        <div class="map-placeholder__badge">Simple and clear</div>
        <h3>Meeting spots are shared when the trip is booked.</h3>
        <p>
          Exact launch points, trailheads, and meetup details can vary by weather, season, trail conditions,
          and the type of trip being booked.
        </p>
        <ul class="tag-list" aria-label="Meeting details">
          <li>{site.location}</li>
          <li>Launch Point Confirmed Later</li>
          <li>Trailhead Confirmed Later</li>
          <li>Weather Dependent</li>
        </ul>
        <a class="button button--secondary" href={`mailto:${site.contactEmail}`}>Ask about trip details</a>
      </div>
    </aside>
  </section>

  <section class="shell section">
    <div class="feature-grid feature-grid--two">
      <article class="feature-card">
        <span class="feature-card__accent">Before A Fishing Trip</span>
        <h3>List meeting times, license reminders, what gear is included, and what guests should bring.</h3>
        <p>Coolers, weather layers, snacks, sunglasses, and any fish-cleaning expectations fit well here.</p>
      </article>
      <article class="feature-card">
        <span class="feature-card__accent">Before A Trail Ride</span>
        <h3>Cover trail conditions, clothing, eye protection, and how muddy or technical the ride may be.</h3>
        <p>This helps guests arrive prepared and keeps last-minute questions down.</p>
      </article>
    </div>
  </section>

  <section class="shell section">
    <div class="callout">
      <div>
        <p class="eyebrow">Trip Readiness</p>
        <h2>Use this page for guest prep, meeting details, weather notes, and what to bring.</h2>
      </div>
      <p>This page works best as a simple pre-trip checklist guests can read quickly from their phone.</p>
    </div>
  </section>
</BaseLayout>
