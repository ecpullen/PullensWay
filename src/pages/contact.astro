---
import { render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import site from "../data/site.json";
import { getPageBySlug } from "../lib/content";

const page = await getPageBySlug("contact");

if (!page) {
  throw new Error("Contact page content is missing.");
}

const { Content } = await render(page);
---

<BaseLayout title={`${page.data.title} | Pullen's Way`} description={page.data.description}>
  <section class="page-hero shell">
    <p class="eyebrow">Reach Out</p>
    <h1>{page.data.title}</h1>
    <p class="page-hero__intro">{page.data.intro}</p>
  </section>

  <section class="shell contact-grid">
    <article class="prose-card">
      <Content />
    </article>

    <aside class="contact-card">
      <p class="eyebrow">Book A Trip</p>
      <h2>Make it easy for guests to ask about dates, trip types, and group size.</h2>
      <ul class="contact-list">
        <li><strong>Email</strong><a href={`mailto:${site.contactEmail}`}>{site.contactEmail}</a></li>
        <li><strong>Phone</strong><span>{site.phone}</span></li>
        <li><strong>Location</strong><span>{site.location}</span></li>
      </ul>
    </aside>
  </section>

  <section class="shell section">
    <div class="feature-grid feature-grid--three">
      <article class="feature-card">
        <span class="feature-card__accent">1. Pick A Trip</span>
        <h3>Fishing, side-by-side riding, boating, canoeing, or winter trips.</h3>
        <p>Guests should know what kind of day they want before they reach out.</p>
      </article>
      <article class="feature-card">
        <span class="feature-card__accent">2. Share Your Group</span>
        <h3>Ask for headcount, ages, experience level, and preferred dates.</h3>
        <p>This helps the business match the trip to the group quickly.</p>
      </article>
      <article class="feature-card">
        <span class="feature-card__accent">3. Confirm Details</span>
        <h3>Cover weather, launch or meeting point, gear, and what the guide provides.</h3>
        <p>This makes the booking process feel organized and professional.</p>
      </article>
    </div>
  </section>
</BaseLayout>
