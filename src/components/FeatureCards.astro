---
import featured from "../data/featured.json";
import { withBase } from "../lib/paths";
---

<div class="feature-grid">
  {
    featured.items.map((item) => (
      <a class="feature-card" href={withBase(item.href)}>
        <span class="feature-card__accent">{item.accent}</span>
        <h3>{item.title}</h3>
        <p>{item.summary}</p>
      </a>
    ))
  }
</div>
