---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import site from "../data/site.json";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const { title = site.siteTitle, description = site.tagline } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}images/pway-logo.png`} />
  </head>
  <body>
    <div class="site-frame">
      <Header />
      <main>
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
